#!/usr/bin/env bash

# 07_cleanup — Post-Engagement Cleanup

# Cleans ALL compromised host types:
#   - MSSQL hosts (from mssql-creds.txt, includes credential-reuse pivots)
#   - PtH hosts   (from pth-successes.txt)

# Each cleanup action is verified and logged. The environment should be
# returned to more or less the same state it was in before the engagement.

# Local recon/loot files are preserved for reporting.


OUTDIR="./recon"
CREDS_FILE="$OUTDIR/hosts/mssql-creds.txt"
PERSIST_DIR="$OUTDIR/persist"
PIVOT_DIR="$OUTDIR/pivot"
CLEANUP_DIR="$OUTDIR/cleanup"
mkdir -p "$CLEANUP_DIR"


# CONFIGURABLE — Must match the value used in 05_persist and 06_pivot

TASK_NAME="WindowsHealthCheck"


PAYLOAD_PATH="c:\\windows\\temp\\healthcheck.ps1"

echo "============================================================"
echo "  Post-Engagement Cleanup"
echo "  Chapter 11: Five Cleanup Categories"
echo "  Started: $(date)"
echo "============================================================"
echo ""
echo "[*] Local recon files will NOT be removed (needed for reporting)."
echo ""

# Counters for summary
TOTAL_CLEANED=0
TOTAL_FAILED=0

# Track what we've already cleaned to avoid double-cleaning
declare -A CLEANED


# Helper: Execute a command on a host using whatever creds we have
# Tries MSSQL xp_cmdshell first, falls back to PtH via nxc
# Used for portproxy cleanup where we need to talk to pivot hosts
# before the per-host cleanup loop starts.

remote_exec_for_cleanup() {
    local HOST="$1"
    local CMD="$2"

    # Check MSSQL creds
    local MSSQL_LINE
    MSSQL_LINE=$(grep "^${HOST}:" "$CREDS_FILE" 2>/dev/null | head -1)
    if [[ -n "$MSSQL_LINE" ]]; then
        local PORT USER PASS
        PORT=$(echo "$MSSQL_LINE" | cut -d: -f2)
        USER=$(echo "$MSSQL_LINE" | cut -d: -f3)
        PASS=$(echo "$MSSQL_LINE" | cut -d: -f4)
        printf "exec master..xp_cmdshell '%s';\nexit\n" "$CMD" | \
            mssqlclient "${USER}:${PASS}@${HOST}" -port "$PORT" 2>&1
        return
    fi

    # Check PtH creds
    local PTH_LINE
    PTH_LINE=$(grep "^${HOST}:" "$PIVOT_DIR/pth-successes.txt" 2>/dev/null | head -1)
    if [[ -n "$PTH_LINE" ]]; then
        local PUSER NTHASH
        PUSER=$(echo "$PTH_LINE" | cut -d: -f2)
        NTHASH=$(echo "$PTH_LINE" | cut -d: -f3)
        nxc smb "$HOST" -u "$PUSER" -H "$NTHASH" -x "$CMD" 2>&1
        return
    fi

    echo "[-] No credentials available for $HOST"
    return 1
}


# Category 1: Active Shell Connections

# Our attack chain doesn't maintain persistent msfconsole sessions, but
# if any nc/ncat listeners are running for the persistence callbacks,
# we should note them. We don't blindly kill processes since the user
# may have other listeners running for legitimate reasons.

echo "  Category 1: Active Shell Connections"
echo ""

LISTENERS=$(ss -tlnp 2>/dev/null | grep -E ":(4444|9001)" || true)
if [[ -n "$LISTENERS" ]]; then
    echo "[!] Active listeners detected that may be from this engagement:"
    echo "$LISTENERS" | sed 's/^/    /'
    echo ""
    echo "[!] These were NOT automatically killed. If they belong to this"
    echo "    engagement, terminate them manually (kill <pid>)."
else
    echo "[+] No engagement-related listeners detected."
fi
echo ""


# Category 2: User Accounts


echo "  Category 2: User Accounts"
echo ""
echo "[+] No user accounts were created during this engagement."
echo "    (This attack chain does not create local/domain accounts.)"
echo ""


# Category 4 (pre-pass): Port Forwarding Rules (netsh portproxy)

# The cleanup order matters for cross-network pivots:
#   1. Clean remote-segment MSSQL hosts FIRST (while portproxy is still active)
#   2. Reset portproxy rules on pivot hosts
#   3. Clean same-segment MSSQL hosts (xp_cmdshell disable is the last step)
#   4. Clean PtH hosts

# Build list of hosts from the original scan (same-segment, directly reachable)
declare -A ORIGINAL_HOSTS
if [[ -f "$OUTDIR/hosts/all-live-hosts.txt" ]]; then
    while read -r H; do
        ORIGINAL_HOSTS["$H"]=1
    done < "$OUTDIR/hosts/all-live-hosts.txt"
fi


echo "  Phase 1: Remote-Segment MSSQL Hosts (via portproxy)"
echo ""

# Clean remote-segment hosts first while portproxy is still active
if [[ -f "$CREDS_FILE" ]]; then
    while IFS=: read -r TARGET_IP TARGET_PORT USER PASS; do
        [[ -z "$USER" || -z "$PASS" ]] && continue
        [[ "${CLEANED[$TARGET_IP]+exists}" ]] && continue
        # Skip same-segment hosts for now
        [[ "${ORIGINAL_HOSTS[$TARGET_IP]+exists}" ]] && continue

        # Find the portproxy mapping for this remote host's MSSQL port
        # portproxy-rules.txt format: PIVOT_HOST|LISTEN_IP|LISTEN_PORT|REMOTE_IP|REMOTE_PORT
        PROXY_LINE=$(grep "|${TARGET_IP}|${TARGET_PORT}" "$PIVOT_DIR/portproxy-rules.txt" 2>/dev/null | head -1)
        if [[ -z "$PROXY_LINE" ]]; then
            echo "[-] No portproxy mapping found for $TARGET_IP:$TARGET_PORT. Skipping."
            continue
        fi

        PROXY_IP=$(echo "$PROXY_LINE" | cut -d'|' -f2)
        PROXY_PORT=$(echo "$PROXY_LINE" | cut -d'|' -f3)

        echo "------------------------------------------------------------"
        echo "[*] Remote Host: $TARGET_IP:$TARGET_PORT (via ${PROXY_IP}:${PROXY_PORT})"
        echo "------------------------------------------------------------"

        SAFE_TARGET="${TARGET_IP//./_}"
        CLEANUP_LOG="$CLEANUP_DIR/${SAFE_TARGET}_cleanup.log"
        > "$CLEANUP_LOG"

        # For remote hosts, connect through the portproxy
        xp_remote() {
            local CMD="$1"
            local ESCAPED_CMD="${CMD//\'/\'\'}"
            printf "exec master..xp_cmdshell '%s';\nexit\n" "$ESCAPED_CMD" | \
                mssqlclient "${USER}:${PASS}@${PROXY_IP}" -port "$PROXY_PORT" 2>&1
        }

        sql_remote() {
            local QUERY="$1"
            printf "%s\nexit\n" "$QUERY" | \
                mssqlclient "${USER}:${PASS}@${PROXY_IP}" -port "$PROXY_PORT" 2>&1
        }

        echo "[*]   [Backdoor] Removing scheduled task '$TASK_NAME'..."
        RESULT=$(xp_remote "schtasks /delete /tn ${TASK_NAME} /f" 2>&1)
        echo "$RESULT" >> "$CLEANUP_LOG"
        if echo "$RESULT" | grep -qi "SUCCESS"; then
            echo "[+]   Scheduled task removed."
        else
            echo "[+]   Scheduled task cleanup attempted."
        fi

        echo "[*]   [Files] Removing payload and hive files..."
        xp_remote "del ${PAYLOAD_PATH}" >> "$CLEANUP_LOG" 2>&1
        xp_remote "del c:\\windows\\temp\\sam" >> "$CLEANUP_LOG" 2>&1
        xp_remote "del c:\\windows\\temp\\sys" >> "$CLEANUP_LOG" 2>&1
        echo "[+]   File cleanup attempted."

        echo "[*]   [Config] Disabling xp_cmdshell..."
        sql_remote "sp_configure 'xp_cmdshell', '0';
RECONFIGURE;
sp_configure 'show advanced options', '0';
RECONFIGURE;" >> "$CLEANUP_LOG" 2>&1
        echo "[+]   xp_cmdshell disabled."

        CLEANED["$TARGET_IP"]=1
        TOTAL_CLEANED=$((TOTAL_CLEANED + 1))
        echo "[+] CLEANUP COMPLETE for remote host $TARGET_IP"
        echo ""

    done < "$CREDS_FILE"
else
    echo "[+] No remote-segment hosts to clean."
    echo ""
fi


# Now reset portproxy rules (after remote hosts are cleaned)

echo "  Phase 2: Port Forwarding Rules (netsh portproxy)"
echo ""

PORTPROXY_FILE="$PIVOT_DIR/portproxy-rules.txt"
if [[ -f "$PORTPROXY_FILE" ]] && [[ -s "$PORTPROXY_FILE" ]]; then
    declare -A PROXY_HOSTS_SEEN
    while IFS='|' read -r PIVOT_HOST LISTEN_IP LISTEN_PORT REMOTE_IP REMOTE_PORT; do
        [[ -z "$PIVOT_HOST" ]] && continue
        PROXY_HOSTS_SEEN["$PIVOT_HOST"]=1
    done < "$PORTPROXY_FILE"

    echo "[*] Portproxy rules found on ${#PROXY_HOSTS_SEEN[@]} pivot host(s)."
    echo ""

    for PIVOT_HOST in "${!PROXY_HOSTS_SEEN[@]}"; do
        echo "[*] Resetting all portproxy rules on $PIVOT_HOST..."
        SAFE_PH="${PIVOT_HOST//./_}"
        PP_LOG="$CLEANUP_DIR/${SAFE_PH}_portproxy_cleanup.log"

        echo "[*]   Current portproxy rules:" >> "$PP_LOG"
        remote_exec_for_cleanup "$PIVOT_HOST" "netsh interface portproxy show all" >> "$PP_LOG" 2>&1

        remote_exec_for_cleanup "$PIVOT_HOST" "netsh interface portproxy reset" >> "$PP_LOG" 2>&1

        VERIFY=$(remote_exec_for_cleanup "$PIVOT_HOST" "netsh interface portproxy show all" 2>&1)
        if echo "$VERIFY" | grep -qi "listenport\|connectaddress"; then
            echo "[-]   WARNING: Portproxy rules may still exist on $PIVOT_HOST."
        else
            echo "[+]   All portproxy rules cleared on $PIVOT_HOST and verified."
        fi
        echo ""
    done
else
    echo "[+] No portproxy rules to clean up."
    echo ""
fi


# Phase 3: Same-segment MSSQL hosts

echo "  Phase 3: Same-Segment MSSQL Hosts"
echo ""

if [[ -f "$CREDS_FILE" ]]; then
    while IFS=: read -r TARGET_IP TARGET_PORT USER PASS; do
        [[ -z "$USER" || -z "$PASS" ]] && continue
        [[ "${CLEANED[$TARGET_IP]+exists}" ]] && continue

        echo "------------------------------------------------------------"
        echo "[*] Host: $TARGET_IP:$TARGET_PORT  |  User: $USER"
        echo "------------------------------------------------------------"

        SAFE_TARGET="${TARGET_IP//./_}"
        CLEANUP_LOG="$CLEANUP_DIR/${SAFE_TARGET}_cleanup.log"
        > "$CLEANUP_LOG"
        HOST_FAILED=0

        # Helper: run OS command via xp_cmdshell (requires xp_cmdshell still enabled)
        xp() {
            local CMD="$1"
            printf "exec master..xp_cmdshell '%s';\nexit\n" "$CMD" | \
                mssqlclient "${USER}:${PASS}@${TARGET_IP}" -port "$TARGET_PORT" 2>&1
        }

        # Helper: run SQL statement
        sql() {
            local QUERY="$1"
            printf "%s\nexit\n" "$QUERY" | \
                mssqlclient "${USER}:${PASS}@${TARGET_IP}" -port "$TARGET_PORT" 2>&1
        }


        # Category 5: Backdoors — Remove scheduled task

        echo "[*]   [Backdoor] Removing scheduled task '$TASK_NAME'..."
        RESULT=$(xp "schtasks /delete /tn ${TASK_NAME} /f" 2>&1)
        echo "$RESULT" >> "$CLEANUP_LOG"

        # Verify removal
        VERIFY=$(xp "schtasks /query /tn ${TASK_NAME}" 2>&1)
        if echo "$VERIFY" | grep -qi "ERROR\|does not exist\|cannot find"; then
            echo "[+]   Scheduled task removed and verified."
        elif echo "$RESULT" | grep -qi "SUCCESS\|successfully"; then
            echo "[+]   Scheduled task reported removed (could not re-query to verify)."
        else
            echo "[-]   WARNING: Could not confirm scheduled task removal."
            echo "[-]   Manual check required: schtasks /query /tn $TASK_NAME"
            HOST_FAILED=1
        fi


        # Category 3: Miscellaneous Files — Remove payload script

        echo "[*]   [Files] Removing payload file $PAYLOAD_PATH..."
        xp "del ${PAYLOAD_PATH}" >> "$CLEANUP_LOG" 2>&1

        # Verify removal
        VERIFY=$(xp "dir ${PAYLOAD_PATH}" 2>&1)
        if echo "$VERIFY" | grep -qi "File Not Found\|cannot find"; then
            echo "[+]   Payload file removed and verified."
        else
            echo "[-]   WARNING: Could not confirm payload file removal."
            echo "[-]   Manual check required: dir $PAYLOAD_PATH"
            HOST_FAILED=1
        fi


        # Category 3: Miscellaneous Files — Remove registry hive copies

        echo "[*]   [Files] Removing registry hive copies from C:\\Windows\\Temp..."
        xp "del c:\\windows\\temp\\sam" >> "$CLEANUP_LOG" 2>&1
        xp "del c:\\windows\\temp\\sys" >> "$CLEANUP_LOG" 2>&1

        # Verify removal of each file individually
        VERIFY=$(xp "dir c:\\windows\\temp\\sam" 2>&1)
        if echo "$VERIFY" | grep -qi "File Not Found\|cannot find"; then
            echo "[+]   SAM hive copy removed and verified."
        else
            echo "[-]   WARNING: Could not confirm SAM hive removal."
            HOST_FAILED=1
        fi

        VERIFY=$(xp "dir c:\\windows\\temp\\sys" 2>&1)
        if echo "$VERIFY" | grep -qi "File Not Found\|cannot find"; then
            echo "[+]   SYSTEM hive copy removed and verified."
        else
            echo "[-]   WARNING: Could not confirm SYSTEM hive removal."
            HOST_FAILED=1
        fi


        # Category 4: Configuration Changes — Remove SMB share

        echo "[*]   [Config] Removing SMB share 'pentest'..."
        xp "net share pentest /delete" >> "$CLEANUP_LOG" 2>&1

        # Verify by checking net share output
        VERIFY=$(xp "net share" 2>&1)
        if echo "$VERIFY" | grep -qi "pentest"; then
            echo "[-]   WARNING: SMB share 'pentest' still appears in net share output."
            echo "[-]   Manual check required: net share"
            HOST_FAILED=1
        else
            echo "[+]   SMB share removed and verified."
        fi


        # Category 4: Configuration Changes — Revert cacls permissions
        # 04_hashdump granted Everyone:F and Anonymous Logon:F on the
        # hive files and the c:\windows\temp directory itself. 

        echo "[*]   [Config] Reverting cacls permissions on C:\\Windows\\Temp..."
        xp "cacls c:\\windows\\temp /E /R \"Anonymous Logon\"" >> "$CLEANUP_LOG" 2>&1
        echo "[+]   Anonymous Logon ACE removed from C:\\Windows\\Temp."


        # Category 4: Configuration Changes — Revert registry modifications
        # RestrictNullSessAccess was set from 1 to 0; restore it to 1.
        # NullSessionShares was set to "pentest"; delete the value entirely.

        echo "[*]   [Config] Reverting anonymous SMB registry modifications..."

        xp "reg add \"HKLM\\SYSTEM\\CurrentControlSet\\Services\\LanmanServer\\Parameters\" /v RestrictNullSessAccess /t REG_DWORD /d 1 /f" >> "$CLEANUP_LOG" 2>&1

        # Verify RestrictNullSessAccess
        VERIFY=$(xp "reg query \"HKLM\\SYSTEM\\CurrentControlSet\\Services\\LanmanServer\\Parameters\" /v RestrictNullSessAccess" 2>&1)
        if echo "$VERIFY" | grep -qi "0x1"; then
            echo "[+]   RestrictNullSessAccess restored to 1 and verified."
        else
            echo "[-]   WARNING: Could not verify RestrictNullSessAccess restoration."
            HOST_FAILED=1
        fi

        xp "reg delete \"HKLM\\SYSTEM\\CurrentControlSet\\Services\\LanmanServer\\Parameters\" /v NullSessionShares /f" >> "$CLEANUP_LOG" 2>&1

        # Verify NullSessionShares removal
        VERIFY=$(xp "reg query \"HKLM\\SYSTEM\\CurrentControlSet\\Services\\LanmanServer\\Parameters\" /v NullSessionShares" 2>&1)
        if echo "$VERIFY" | grep -qi "ERROR\|not found\|unable to find"; then
            echo "[+]   NullSessionShares registry value deleted and verified."
        else
            echo "[-]   WARNING: NullSessionShares may still exist in registry."
            HOST_FAILED=1
        fi


        # Category 4: Configuration Changes — Restart LanmanServer
        # The registry changes to the SMB sharing configuration do NOT
        # take effect until the Server service (LanmanServer) is restarted.
        # This mirrors what 04_hashdump does when it modifies these values.

        echo "[*]   [Config] Restarting LanmanServer to apply registry reverts..."
        xp "net stop LanmanServer" >> "$CLEANUP_LOG" 2>&1
        sleep 3
        xp "net start LanmanServer" >> "$CLEANUP_LOG" 2>&1
        sleep 3

        # Verify service came back up
        VERIFY=$(xp "sc query LanmanServer" 2>&1)
        if echo "$VERIFY" | grep -qi "RUNNING"; then
            echo "[+]   LanmanServer restarted and verified running."
        else
            echo "[-]   WARNING: Could not verify LanmanServer is running."
            echo "[-]   Manual check required: sc query LanmanServer"
            HOST_FAILED=1
        fi


        # Category 4: Configuration Changes — Disable xp_cmdshell
        #
        # >>> THIS MUST BE THE LAST CLEANUP STEP <<<
        # All previous steps depend on xp_cmdshell to run OS commands.
        # Once we disable it, we lose command execution on the target.

        echo "[*]   [Config] Disabling xp_cmdshell and hiding advanced options..."
        RESULT=$(sql "sp_configure 'xp_cmdshell', '0';
RECONFIGURE;
sp_configure 'show advanced options', '0';
RECONFIGURE;" 2>&1)
        echo "$RESULT" >> "$CLEANUP_LOG"

        # Verify by trying to invoke xp_cmdshell (should be blocked)
        VERIFY=$(sql "exec master..xp_cmdshell 'whoami';" 2>&1)
        if echo "$VERIFY" | grep -qi "blocked access\|turned off\|not exist"; then
            echo "[+]   xp_cmdshell disabled and verified."
        else
            echo "[-]   WARNING: xp_cmdshell may still be enabled."
            echo "[-]   Manual check: sp_configure 'xp_cmdshell'"
            HOST_FAILED=1
        fi


        # Host summary

        CLEANED["$TARGET_IP"]=1
        if [[ $HOST_FAILED -eq 0 ]]; then
            echo "[+] CLEANUP COMPLETE for $TARGET_IP -- all actions verified."
            TOTAL_CLEANED=$((TOTAL_CLEANED + 1))
        else
            echo "[!] CLEANUP COMPLETE for $TARGET_IP -- some actions need manual verification."
            echo "[!] Review log: $CLEANUP_LOG"
            TOTAL_FAILED=$((TOTAL_FAILED + 1))
        fi
        echo ""

    done < "$CREDS_FILE"
else
    echo "[-] No MSSQL creds file found. Skipping MSSQL host cleanup."
    echo ""
fi



# Phase 2: PtH-Compromised Hosts

echo "  Categories 3-5: PtH-Compromised Hosts"
echo ""

PTH_FILE="$PIVOT_DIR/pth-successes.txt"
if [[ -f "$PTH_FILE" ]]; then
    while IFS=: read -r HOST PUSER NTHASH; do
        [[ -z "$HOST" || -z "$NTHASH" ]] && continue
        [[ "${CLEANED[$HOST]+exists}" ]] && continue

        echo "------------------------------------------------------------"
        echo "[*] PtH Host: $HOST  |  User: $PUSER"
        echo "------------------------------------------------------------"

        SAFE_HOST="${HOST//./_}"
        CLEANUP_LOG="$CLEANUP_DIR/${SAFE_HOST}_pth_cleanup.log"
        > "$CLEANUP_LOG"
        HOST_FAILED=0

        # Helper: run command via nxc PtH
        pth_exec() {
            local CMD="$1"
            nxc smb "$HOST" -u "$PUSER" -H "$NTHASH" -x "$CMD" 2>&1
        }


        # Category 5: Backdoors — Remove scheduled task

        echo "[*]   [Backdoor] Removing scheduled task '$TASK_NAME'..."
        RESULT=$(pth_exec "schtasks /delete /tn ${TASK_NAME} /f" 2>&1)
        echo "$RESULT" >> "$CLEANUP_LOG"

        # Verify
        VERIFY=$(pth_exec "schtasks /query /tn ${TASK_NAME}" 2>&1)
        if echo "$VERIFY" | grep -qi "ERROR\|does not exist\|cannot find"; then
            echo "[+]   Scheduled task removed and verified."
        elif echo "$RESULT" | grep -qi "SUCCESS\|successfully"; then
            echo "[+]   Scheduled task reported removed."
        else
            echo "[-]   WARNING: Could not confirm scheduled task removal."
            HOST_FAILED=1
        fi


        # Category 3: Miscellaneous Files — Remove payload script

        echo "[*]   [Files] Removing payload file..."
        pth_exec "del ${PAYLOAD_PATH}" >> "$CLEANUP_LOG" 2>&1

        # Verify
        VERIFY=$(pth_exec "dir ${PAYLOAD_PATH}" 2>&1)
        if echo "$VERIFY" | grep -qi "File Not Found\|cannot find"; then
            echo "[+]   Payload file removed and verified."
        else
            echo "[-]   WARNING: Could not confirm payload file removal."
            HOST_FAILED=1
        fi


        # Category 3: Miscellaneous Files — Remove registry hive copies
        # secretsdump.py via PtH does NOT leave files on disk (it reads
        # the hives remotely over SMB). However, if the recursive segment
        # scanner ran the full MSSQL attack chain on this host first, there
        # may be leftover hive copies.

        echo "[*]   [Files] Checking for and removing any hive copies..."
        pth_exec "del c:\\windows\\temp\\sam" >> "$CLEANUP_LOG" 2>&1
        pth_exec "del c:\\windows\\temp\\sys" >> "$CLEANUP_LOG" 2>&1

        VERIFY_SAM=$(pth_exec "dir c:\\windows\\temp\\sam" 2>&1)
        VERIFY_SYS=$(pth_exec "dir c:\\windows\\temp\\sys" 2>&1)
        if echo "$VERIFY_SAM" | grep -qi "File Not Found\|cannot find" && \
           echo "$VERIFY_SYS" | grep -qi "File Not Found\|cannot find"; then
            echo "[+]   No hive copies found (or removed successfully)."
        else
            echo "[-]   WARNING: Hive copies may still exist. Manual check needed."
            HOST_FAILED=1
        fi


        # Category 4: Configuration Changes — Check for SMB share
        # If the share exists, remove it and revert all associated changes.

        echo "[*]   [Config] Checking for SMB share 'pentest'..."
        SHARE_CHECK=$(pth_exec "net share" 2>&1)
        if echo "$SHARE_CHECK" | grep -qi "pentest"; then
            echo "[*]   SMB share 'pentest' found. Removing..."
            pth_exec "net share pentest /delete" >> "$CLEANUP_LOG" 2>&1
            echo "[+]   SMB share removed."

            # Revert the associated registry and permission changes
            echo "[*]   [Config] Reverting associated cacls, registry, and LanmanServer..."
            pth_exec "cacls c:\\windows\\temp /E /R \"Anonymous Logon\"" >> "$CLEANUP_LOG" 2>&1
            pth_exec "reg add \"HKLM\\SYSTEM\\CurrentControlSet\\Services\\LanmanServer\\Parameters\" /v RestrictNullSessAccess /t REG_DWORD /d 1 /f" >> "$CLEANUP_LOG" 2>&1
            pth_exec "reg delete \"HKLM\\SYSTEM\\CurrentControlSet\\Services\\LanmanServer\\Parameters\" /v NullSessionShares /f" >> "$CLEANUP_LOG" 2>&1

            echo "[*]   [Config] Restarting LanmanServer..."
            pth_exec "net stop LanmanServer" >> "$CLEANUP_LOG" 2>&1
            sleep 3
            pth_exec "net start LanmanServer" >> "$CLEANUP_LOG" 2>&1
            sleep 3
            echo "[+]   LanmanServer restarted."
        else
            echo "[+]   No 'pentest' SMB share found on this host."
        fi


        # Host summary

        CLEANED["$HOST"]=1
        if [[ $HOST_FAILED -eq 0 ]]; then
            echo "[+] CLEANUP COMPLETE for PtH host $HOST -- all actions verified."
            TOTAL_CLEANED=$((TOTAL_CLEANED + 1))
        else
            echo "[!] CLEANUP COMPLETE for PtH host $HOST -- some actions need manual verification."
            echo "[!] Review log: $CLEANUP_LOG"
            TOTAL_FAILED=$((TOTAL_FAILED + 1))
        fi
        echo ""

    done < "$PTH_FILE"
else
    echo "[-] No PtH successes file found. Skipping PtH host cleanup."
    echo ""
fi



# Final Summary


echo "  Cleanup Summary"

echo ""
echo "[+] Hosts cleaned successfully:        $TOTAL_CLEANED"
if [[ $TOTAL_FAILED -gt 0 ]]; then
    echo "[!] Hosts needing manual verification: $TOTAL_FAILED"
fi
echo "[+] Total hosts processed:             ${#CLEANED[@]}"
echo ""
echo "[+] Cleaned hosts:"
printf '    %s\n' "${!CLEANED[@]}"
echo ""

if [[ $TOTAL_FAILED -gt 0 ]]; then
    echo "[!] Some cleanup actions could not be verified automatically."
    echo "[!] Review the cleanup logs in $CLEANUP_DIR/ and manually"
    echo "    confirm that all artifacts have been removed."
    echo ""
    echo "[!] Cleanup logs:"
    find "$CLEANUP_DIR" -name "*.log" -type f | sed 's/^/    /'
    echo ""
fi

echo "[+] Cleanup checklist (Chapter 11):"
echo "    [x] 1. Active shell connections -- checked for listeners"
echo "    [x] 2. User accounts -- N/A (none created by this chain)"
echo "    [x] 3. Miscellaneous files -- registry hive copies, payload scripts"
echo "    [x] 4. Configuration changes -- xp_cmdshell, SMB shares, registry, cacls, LanmanServer, portproxy"
echo "    [x] 5. Backdoors -- scheduled tasks, payload files"
echo ""
echo "[+] All remote artifacts reverted. Local recon data preserved in $OUTDIR/"
echo "[+] Cleanup finished: $(date)"
