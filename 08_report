#!/usr/bin/env bash

# 08_report — Penetration Test Deliverable Generator

# Generates a PDF report following the eight-component structure from
# Chapter 12:

#   1. Executive Summary
#   2. Engagement Methodology
#   3. Attack Narrative
#   4. Technical Observations (Findings)
#   5. Appendix A: Severity Definitions (with MITRE ATT&CK TTPs)
#   6. Appendix B: Hosts and Services
#   7. Appendix C: Tool List
#   8. Appendix D: Additional References

# Automatically pulls scope/CIDR from recon data (no user input needed).
# Automatically detects discovered domains from recon output.

# Uses pandoc + xelatex to convert Markdown to PDF.


OUTDIR="./recon"
CREDS_FILE="$OUTDIR/hosts/mssql-creds.txt"
LOOT_DIR="$OUTDIR/loot"
PERSIST_DIR="$OUTDIR/persist"
PIVOT_DIR="$OUTDIR/pivot"
MSSQL_DIR="$OUTDIR/mssql"
TASK_NAME="WindowsHealthCheck"
LPORT="${1:-4444}"
TIMESTAMP=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
DATE_LABEL=$(date +"%Y-%m-%d")
MD_FILE="/tmp/pentest_report_${DATE_LABEL}.md"
PDF_FILE="./pentest_report_${DATE_LABEL}.pdf"

#--
# Gather engagement context (auto-detect where possible)
#--
gather_context() {
    echo "[*] Report context -- press Enter to accept defaults"
    echo ""

    read -p "    Tester name [$(whoami)]: " TESTER_NAME
    TESTER_NAME="${TESTER_NAME:-$(whoami)}"

    read -p "    Client / organization name [Capsulecorp]: " CLIENT_NAME
    CLIENT_NAME="${CLIENT_NAME:-Capsulecorp}"

    read -p "    Target environment name [Internal Network]: " ENV_NAME
    ENV_NAME="${ENV_NAME:-Internal Network}"

    # Auto-detect scope from saved scope file
    SCOPE=""
    if [[ -f "$OUTDIR/scope.txt" ]]; then
        SCOPE=$(cat "$OUTDIR/scope.txt" | paste -sd", " -)
    fi
    if [[ -z "$SCOPE" && -f "$OUTDIR/hosts/ping-sweep.gnmap" ]]; then
        SCOPE=$(head -1 "$OUTDIR/hosts/ping-sweep.gnmap" | grep -oP '(?<=nmap -n -sn )\S+' || true)
    fi
    SCOPE="${SCOPE:-unknown}"
    echo "    Scope (auto-detected): $SCOPE"

    # Count hosts from recon data
    LIVE_HOSTS=0
    [[ -f "$OUTDIR/hosts/all-live-hosts.txt" ]] && LIVE_HOSTS=$(wc -l < "$OUTDIR/hosts/all-live-hosts.txt")
    WINDOWS_HOSTS=0
    [[ -f "$OUTDIR/hosts/targets.txt" ]] && WINDOWS_HOSTS=$(wc -l < "$OUTDIR/hosts/targets.txt")
    COMPROMISED_HOSTS=0
    [[ -f "$CREDS_FILE" ]] && COMPROMISED_HOSTS=$(wc -l < "$CREDS_FILE")

    # Count PtH compromised hosts
    PTH_HOSTS=0
    [[ -f "$PIVOT_DIR/pth-successes.txt" ]] && PTH_HOSTS=$(wc -l < "$PIVOT_DIR/pth-successes.txt")
    TOTAL_COMPROMISED=$((COMPROMISED_HOSTS + PTH_HOSTS))

    # Detect domains from recon output
    DOMAINS=""
    if [[ -d "$MSSQL_DIR" ]]; then
        DOMAINS=$(grep -rhi "Primary Dns Suffix" "$MSSQL_DIR"/ "$PIVOT_DIR"/ 2>/dev/null | \
            grep -oP ':\s*\K[a-zA-Z0-9.-]+\.[a-zA-Z]{2,}' | sort -u | paste -sd", " - 2>/dev/null || true)
    fi

    # Detect new network segments
    NEW_SEGMENTS=""
    if [[ -f "$PIVOT_DIR/networks-discovered.txt" ]]; then
        NEW_SEGMENTS=$(cat "$PIVOT_DIR/networks-discovered.txt" | paste -sd", " -)
    fi

    # Count MSSQL targets
    MSSQL_COUNT=0
    [[ -f "$OUTDIR/hosts/mssql-targets.txt" ]] && MSSQL_COUNT=$(wc -l < "$OUTDIR/hosts/mssql-targets.txt")

    echo ""
    echo "[+] Context set:"
    echo "    Tester:       $TESTER_NAME"
    echo "    Client:       $CLIENT_NAME"
    echo "    Environment:  $ENV_NAME"
    echo "    Scope:        $SCOPE"
    echo "    Live hosts:   $LIVE_HOSTS"
    echo "    Compromised:  $TOTAL_COMPROMISED"
    [[ -n "$DOMAINS" ]] && echo "    Domains:      $DOMAINS"
    [[ -n "$NEW_SEGMENTS" ]] && echo "    New segments: $NEW_SEGMENTS"
    echo ""
}

#--
# Dependency check
#--
check_deps() {
    local MISSING=0
    if ! command -v pandoc &> /dev/null; then
        echo "[-] pandoc not found. Installing..."
        sudo apt-get update -qq && sudo apt-get install -y -qq pandoc
        MISSING=1
    fi
    if ! dpkg -l | grep -q texlive-xetex; then
        echo "[-] texlive-xetex not found. Installing..."
        sudo apt-get update -qq && sudo apt-get install -y -qq texlive-xetex texlive-fonts-recommended
        MISSING=1
    fi
    if [[ $MISSING -eq 1 ]]; then
        echo "[+] Dependencies installed."
    fi
}

