                VERSION=$(echo "$LINE" | awk '{$1=$2=$3=""; print $0}' | sed 's/^[[:space:]]*//')
                VERSION="${VERSION:-(unknown)}"
                if [[ -n "$CURRENT_HOST" ]]; then
                    echo "| $CURRENT_HOST | $PORT | TCP | $SERVICE | $VERSION |" >> "$MD_FILE"
                fi
            fi
        done < "$SVCFILE"
