                fi
            fi
        done < "$OUTDIR/services/full-service.nmap"
        echo "" >> "$MD_FILE"
    else
        echo "Service scan data not available." >> "$MD_FILE"
        echo "" >> "$MD_FILE"
    fi

    # Add any additional segment service data
    for SVCFILE in "$OUTDIR"/services/service_*.nmap; do
        [[ -f "$SVCFILE" ]] || continue
        SEGMENT_NAME=$(basename "$SVCFILE" .nmap | sed 's/^service_//' | sed 's/_/./g; s/\.\([0-9]*\)$/\/\1/')
        echo "### Additional Segment: $SEGMENT_NAME" >> "$MD_FILE"
        echo "" >> "$MD_FILE"
        echo "| IP Address | Port | Protocol | Service | Version |" >> "$MD_FILE"
        echo "|------------|------|----------|---------|---------|" >> "$MD_FILE"

