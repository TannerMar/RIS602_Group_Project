#!/usr/bin/env bash

# 01_recon — Network Reconnaissance

# Performs a proper five-phase recon:
#   Phase 1: Host discovery (ping sweep)
#   Phase 2: Full TCP port scan on all live hosts
#   Phase 3: Service/version detection on all open ports (banner grabbing)
#   Phase 4: Filter to Windows-only hosts (based on service signatures)
#   Phase 5: Banner analysis to identify MSSQL servers

CIDR="$1"

LHOST="$2"

if [[ -z "$CIDR" ]]; then
    echo "Usage: $0 <cidr>"
    exit 1
fi

if [[ -z "$LHOST" ]]; then
    read -p "Please enter in your IP on this Network: " LHOST
fi

if [[ -z "$LHOST" ]]; then 
    echo "[-] No local host provided. Exiting."
    exit 1
fi

OUTDIR="./recon"
mkdir -p "$OUTDIR/hosts" "$OUTDIR/services"

ALL_HOSTS_FILE="$OUTDIR/hosts/all-live-hosts.txt"
TARGETS_FILE="$OUTDIR/hosts/targets.txt"
ALL_PORTS_FILE="$OUTDIR/hosts/all-open-ports.txt"
MSSQL_FILE="$OUTDIR/hosts/mssql-targets.txt"

# Save the scanned scope for the report generator to pick up automatically
echo "$CIDR" > "$OUTDIR/scope.txt"

echo "[*] Starting recon on $CIDR"
echo ""


# Phase 1: Host Discovery

echo "[*] Phase 1: Host discovery (ping sweep)..."
nmap -n -sn "$CIDR" --min-rate 10000 \
    -oG "$OUTDIR/hosts/ping-sweep.gnmap" --exclude $LHOST > /dev/null

grep "Up$" "$OUTDIR/hosts/ping-sweep.gnmap" | awk '{print $2}' > "$ALL_HOSTS_FILE"

LIVE_COUNT=$(wc -l < "$ALL_HOSTS_FILE")
echo "[+] Found $LIVE_COUNT live host(s)"
cat "$ALL_HOSTS_FILE" | sed 's/^/    /'
echo ""

if [[ $LIVE_COUNT -eq 0 ]]; then
    echo "[-] No live hosts found. Exiting."
    exit 1
fi


# Phase 2: Full TCP Port Scan (all hosts, all OS types)

echo "[*] Phase 2: Full TCP port scan on all live hosts..."
echo "[*] This may take a few minutes, especially for larger networks."
nmap -Pn -n -p- -iL "$ALL_HOSTS_FILE" --min-rate 100000 \
    -oG "$OUTDIR/services/full-port-sweep.gnmap" > /dev/null

# Parse all open ports into IP:PORT pairs
> "$ALL_PORTS_FILE"
grep "/open/" "$OUTDIR/services/full-port-sweep.gnmap" | while read -r LINE; do
    HOST=$(echo "$LINE" | awk '{print $2}')
    echo "$LINE" | grep -oP '\d+/open' | cut -d/ -f1 | while read -r PORT; do
        echo "${HOST}:${PORT}" >> "$ALL_PORTS_FILE"
    done
done

OPEN_COUNT=$(wc -l < "$ALL_PORTS_FILE")
echo "[+] Found $OPEN_COUNT open port(s) across all hosts"
echo ""

if [[ $OPEN_COUNT -eq 0 ]]; then
    echo "[-] No open ports found. Exiting."
    exit 1
fi


# Phase 3: Service/Version Detection (per-host, open ports only)

echo "[*] Phase 3: Service and version detection on open ports..."

> "$OUTDIR/services/full-service.gnmap"
> "$OUTDIR/services/full-service.nmap"

cut -d: -f1 "$ALL_PORTS_FILE" | sort -u | while read -r HOST; do
    HOST_PORTS=$(grep "^${HOST}:" "$ALL_PORTS_FILE" | cut -d: -f2 | paste -sd, -)
    PORT_COUNT=$(grep -c "^${HOST}:" "$ALL_PORTS_FILE")
    echo "[*]   $HOST ($PORT_COUNT open ports)..."
    nmap -Pn -n -sV --version-intensity 2 -v \
        -p "$HOST_PORTS" "$HOST" \
        --append-output -oG "$OUTDIR/services/full-service.gnmap" \
        --append-output -oN "$OUTDIR/services/full-service.nmap" # > /dev/null 2>&1
done

echo "[+] Service scan complete. Results saved to:"
echo "    $OUTDIR/services/full-service.gnmap"
echo "    $OUTDIR/services/full-service.nmap"
echo ""

# Phase 4: Filter to Windows Hosts Only

# Parse the service scan results for Windows indicators:
#   - microsoft-ds (SMB on 445)
#   - netbios-ssn (NetBIOS on 139)
#   - ms-wbt-server (RDP on 3389)
#   - ms-sql (MSSQL)
#   - Microsoft Windows in any version string

echo "[*] Phase 4: Filtering for Windows hosts..."
> "$TARGETS_FILE"

if [[ -f "$OUTDIR/services/full-service.nmap" ]]; then
    CURRENT_HOST=""
    declare -A WINDOWS_HOSTS
    while IFS= read -r LINE; do
        if echo "$LINE" | grep -qP '^Nmap scan report for'; then
            CURRENT_HOST=$(echo "$LINE" | grep -oP '[\d]+\.[\d]+\.[\d]+\.[\d]+')
        fi
        if [[ -n "$CURRENT_HOST" ]] && echo "$LINE" | grep -qiP 'microsoft-ds|netbios-ssn|ms-wbt-server|ms-sql|Microsoft Windows'; then
            if [[ -z "${WINDOWS_HOSTS[$CURRENT_HOST]+exists}" ]]; then
                echo "$CURRENT_HOST" >> "$TARGETS_FILE"
                WINDOWS_HOSTS["$CURRENT_HOST"]=1
            fi
        fi
    done < "$OUTDIR/services/full-service.nmap"
fi

WIN_COUNT=$(wc -l < "$TARGETS_FILE")
echo "[+] $WIN_COUNT Windows host(s) identified"
cat "$TARGETS_FILE" | sed 's/^/    /'
echo ""

if [[ $WIN_COUNT -eq 0 ]]; then
    echo "[-] No Windows hosts found. PtH will have no targets."
    echo "[-] Continuing to check for MSSQL..."
fi


# Phase 5: Identify MSSQL Servers from Banner/Service Data

echo "[*] Phase 5: Identifying MSSQL servers from service banners..."
> "$MSSQL_FILE"

# Search for ms-sql, mssql, Microsoft SQL Server in the gnmap output
# This catches MSSQL on ANY port, not just 1433
grep -i "ms-sql\|mssql\|microsoft sql\|ms-sql-s" "$OUTDIR/services/full-service.gnmap" | while read -r LINE; do
    HOST=$(echo "$LINE" | awk '{print $2}')
    echo "$LINE" | grep -oP '\d+/open/tcp//[^/]*ms-sql[^/]*|/\d+/open/tcp//[^/]*mssql[^/]*|/\d+/open/tcp//[^/]*microsoft sql[^/]*' | \
        grep -oP '^\d+' | while read -r PORT; do
            echo "${HOST}:${PORT}" >> "$MSSQL_FILE"
        done
done

# Fallback: also parse the normal-format nmap output for better matching
if [[ -f "$OUTDIR/services/full-service.nmap" ]]; then
    CURRENT_HOST=""
    while IFS= read -r LINE; do
        if echo "$LINE" | grep -qP '^Nmap scan report for'; then
            CURRENT_HOST=$(echo "$LINE" | grep -oP '[\d]+\.[\d]+\.[\d]+\.[\d]+')
        fi
        if echo "$LINE" | grep -qiP '^\d+/tcp\s+open\s+.*ms-sql|^\d+/tcp\s+open\s+.*mssql|^\d+/tcp\s+open\s+.*microsoft sql'; then
            PORT=$(echo "$LINE" | grep -oP '^\d+')
            if [[ -n "$CURRENT_HOST" && -n "$PORT" ]]; then
                echo "${CURRENT_HOST}:${PORT}" >> "$MSSQL_FILE"
            fi
        fi
    done < "$OUTDIR/services/full-service.nmap"
fi

# Deduplicate
if [[ -f "$MSSQL_FILE" ]]; then
    sort -u "$MSSQL_FILE" -o "$MSSQL_FILE"
fi

MSSQL_COUNT=$(wc -l < "$MSSQL_FILE")
echo "[+] $MSSQL_COUNT MSSQL target(s) confirmed via service banners"

if [[ $MSSQL_COUNT -eq 0 ]]; then
    echo "[-] No MSSQL servers found in the scanned environment."
    exit 1
fi

cat "$MSSQL_FILE" | sed 's/^/    /'
echo ""
echo "[+] Recon phase complete."
